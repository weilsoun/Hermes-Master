# Hermes Agent — Docker Environment
# Provider: OpenRouter (all models via one key)

# =============================================================================
# OPENROUTER — Primary LLM Provider
# =============================================================================
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# =============================================================================
# TOOL API KEYS (optional — enhance agent capabilities)
# =============================================================================

# Web search & extract
# EXA_API_KEY=
# PARALLEL_API_KEY=
# FIRECRAWL_API_KEY=

# Image generation (FLUX via fal.ai)
# FAL_KEY=

# Browser automation (Browserbase)
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
BROWSERBASE_PROXIES=true
BROWSERBASE_ADVANCED_STEALTH=false

# Voice transcription (OpenAI Whisper)
# VOICE_TOOLS_OPENAI_KEY=

# Cross-session memory (Honcho)
# HONCHO_API_KEY=

# =============================================================================
# MESSAGING PLATFORMS (optional — enable any gateway)
# =============================================================================

# Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=
# TELEGRAM_HOME_CHANNEL=

# Discord
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=

# Slack
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# WhatsApp (Baileys bridge)
# WHATSAPP_ENABLED=false

# Email (IMAP/SMTP)
# EMAIL_ADDRESS=
# EMAIL_PASSWORD=
# EMAIL_IMAP_HOST=imap.gmail.com
# EMAIL_SMTP_HOST=smtp.gmail.com

# Allow all users on gateway (default: deny unknown)
# GATEWAY_ALLOW_ALL_USERS=false

# =============================================================================
# GITHUB (for skills hub and git operations)
# =============================================================================
# GITHUB_TOKEN=

# =============================================================================
# TERMINAL — No limits
# =============================================================================
TERMINAL_TIMEOUT=0
TERMINAL_LIFETIME_SECONDS=0

# =============================================================================
# DEBUG
# =============================================================================
WEB_TOOLS_DEBUG=false
VISION_TOOLS_DEBUG=false
MOA_TOOLS_DEBUG=false
IMAGE_TOOLS_DEBUG=false
